#!/usr/bin/env bash
# PreToolUse hook for QRSPI plugin.
#
# Asymmetric target-based enforcement:
#   - Subagents (envelope.agent_id non-empty) are walled inside
#     .worktrees/{slug}/task-NN/ (loose pinning — any worktree)
#   - Main chat is trusted; only pipeline ordering and universal-destructive
#     checks apply.
#   - Detection is target-based: the hook inspects what the operation TARGETS
#     (file path, parsed Bash write targets), never the agent's CWD.
#
# Audits land in <artifact_dir>/.qrspi/audit.jsonl when the target is in
# QRSPI scope. Non-QRSPI writes are not audited (no pollution).
#
# ## Containment Notes
#
# Containment is intentionally TARGET-BASED, not CWD-based. The hook decides
# allow/block by inspecting the operation's target (Write/Edit file_path,
# Bash-detected write paths), never by inspecting where the subagent's shell
# is currently running.
#
# Consequences:
#
#   1. Subagent CWD reads outside the worktree are intentionally NOT contained.
#      Non-write Bash with `cd ..` (e.g., `cd /tmp && ls` or
#      `cd ../sibling && cat foo`) is permitted — it does not violate the
#      write-containment guarantee, and trying to contain it would require
#      shell-state tracking the hook does not do.
#      L-sec-3 (round-2 review): documented here per the target-based model.
#
#   2. Subagent WRITES outside the worktree ARE contained, even via cd.
#      Specifically, `cd /tmp && echo x > escaped.txt` — where the shell's
#      effective CWD diverges from the hook PWD before a relative-path
#      write — is detected by `bash_detect_file_writes` and treated as
#      opaque (`__OPAQUE_WRITE__` sentinel). The wall blocks because the
#      sentinel is not under any worktree path. See task-43 S-2 fix in
#      `hooks/lib/bash-detect.sh` (the `cd_escaped` tracking after compound
#      splitting).
#
#   3. Main chat is exempt from the worktree wall. Both the read and write
#      cases above apply only to subagents.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

source "$PLUGIN_ROOT/hooks/lib/pipeline.sh"
source "$PLUGIN_ROOT/hooks/lib/bash-detect.sh"
source "$PLUGIN_ROOT/hooks/lib/worktree.sh"
source "$PLUGIN_ROOT/hooks/lib/agent.sh"
source "$PLUGIN_ROOT/hooks/lib/audit.sh"
source "$PLUGIN_ROOT/hooks/lib/protected.sh"

block() {
  local reason="$1"
  # Important #3: keep `|| true` (don't fail the hook on audit failure), but
  # drop `2>/dev/null` so audit diagnostics (e.g., ambiguous-slug warnings) reach
  # the operator's stderr instead of being swallowed.
  audit_log_event "$STDIN_JSON" "block" "$reason" || true
  echo "pre-tool-use: BLOCKED: ${reason}" >&2
  jq -cn --arg r "$reason" '{decision:"block",reason:$r}'
  exit 2
}

allow() {
  audit_log_event "$STDIN_JSON" "allow" "" || true
  printf '{}\n'
  exit 0
}

# ── Read stdin ───────────────────────────────────────────────────────────────
STDIN_JSON=$(cat)

tool_name=$(printf '%s' "$STDIN_JSON" | jq -r '.tool_name // empty' 2>/dev/null) || {
  block "Cannot parse tool call: malformed JSON on stdin."
}

if [[ -z "$tool_name" ]]; then
  block "Cannot parse tool call: missing tool_name field."
fi

# Tools we don't enforce — intentionally not audited (audit captures
# enforcement decisions for Write/Edit/NotebookEdit/Bash, not every read).
case "$tool_name" in
  Read|Glob|Grep|Skill|ToolSearch|Agent|TodoRead|TodoWrite|WebFetch|WebSearch)
    printf '{}\n'
    exit 0
    ;;
esac

# Determine if we're a subagent
is_subagent=0
if agent_is_subagent "$STDIN_JSON"; then
  is_subagent=1
fi

# Extract tool-specific fields
file_path=""
bash_command=""
case "$tool_name" in
  Write|Edit|NotebookEdit)
    file_path=$(printf '%s' "$STDIN_JSON" | jq -r '.tool_input.file_path // empty' 2>/dev/null) || {
      block "Cannot parse ${tool_name} target: malformed tool_input."
    }
    [[ -z "$file_path" ]] && block "Cannot parse ${tool_name} target: missing file_path."
    ;;
  Bash)
    bash_command=$(printf '%s' "$STDIN_JSON" | jq -r '.tool_input.command // empty' 2>/dev/null) || {
      block "Cannot parse Bash command: malformed tool_input."
    }
    ;;
  *)
    echo "pre-tool-use: WARNING: unknown tool_name '${tool_name}' — not enforced" >&2
    printf '{}\n'
    exit 0
    ;;
esac

# ── Pipeline ordering check (Write/Edit/NotebookEdit on artifact paths only) ──
# Runs for both main chat and subagents — protects QRSPI artifact ordering
# regardless of who's writing. The artifact_dir is resolved target-based via the
# audit resolver: state.json lives at <artifact_dir>/.qrspi/state.json per spec,
# so we have to know which artifact_dir before we can read it.
if [[ "$tool_name" == "Write" || "$tool_name" == "Edit" || "$tool_name" == "NotebookEdit" ]]; then
  artifact_step=""
  artifact_step=$(artifact_map_get_step "$file_path" 2>/dev/null) || true

  if [[ -n "$artifact_step" ]]; then
    # Resolve target → artifact_dir. Convert relative paths to absolute first
    # so the resolver's prefix match against $(pwd)/docs/qrspi/ works.
    abs_file_path="$file_path"
    [[ "$file_path" != /* ]] && abs_file_path="$PWD/$file_path"
    pipeline_artifact_dir=""
    pipeline_artifact_dir=$(_audit_resolve_target_to_artifact_dir "$abs_file_path" 2>/dev/null) || pipeline_artifact_dir=""

    if [[ -z "$pipeline_artifact_dir" ]]; then
      # Fail-closed: target matches a known artifact step (per artifact_map_get_step)
      # but the resolver cannot map it to an artifact_dir. Either (a) the path
      # is a legit non-QRSPI file with a colliding basename, or (b) it IS a real
      # QRSPI artifact but the layout doesn't match $(pwd)/docs/qrspi/*-{slug}/
      # (e.g., relative path from a nonstandard CWD, monorepo with docs/qrspi/
      # not at PWD-root, ambiguous slug). Allowing (b) silently bypasses
      # pipeline ordering — security regression. Block both cases; (a) friction
      # is recoverable by renaming or by running QRSPI from the correct CWD.
      block "Cannot enforce pipeline ordering for ${file_path}: target matches a QRSPI artifact name but no artifact_dir resolved. If this is non-QRSPI work, rename or move outside docs/qrspi/-shaped paths. If this is a QRSPI artifact, run from the project root so docs/qrspi/*-{slug}/ resolves."
    elif [[ ! -f "$pipeline_artifact_dir/.qrspi/state.json" ]]; then
      echo "pre-tool-use: WARNING: no state file found at ${pipeline_artifact_dir}/.qrspi/ — pipeline ordering not enforced for ${artifact_step}" >&2
    else
      missing_step=$(pipeline_check_prerequisites "$artifact_step" "$pipeline_artifact_dir") || {
        case "$missing_step" in
          "<state-corrupted>")
            block "Cannot verify pipeline ordering: state.json at ${pipeline_artifact_dir}/.qrspi/ is corrupted (not a JSON object with required version/artifacts fields)"
            ;;
          "<state-unavailable>")
            block "Cannot verify pipeline ordering: state.json unreadable at ${pipeline_artifact_dir}/.qrspi/"
            ;;
          *)
            block "Complete and approve ${missing_step} before writing $(basename "$file_path")"
            ;;
        esac
      }
    fi
  fi
fi

# ── Bash policy: universal destructive check (everyone) ──────────────────────
if [[ "$tool_name" == "Bash" && -n "$bash_command" ]]; then
  destructive=$(bash_detect_destructive_universal "$bash_command" 2>/dev/null) || destructive=""
  if [[ -n "$destructive" ]]; then
    block "Destructive command blocked: $destructive"
  fi
fi

# ── Subagent-only checks ─────────────────────────────────────────────────────
if [[ $is_subagent -eq 1 ]]; then

  # Subagent destructive Bash check
  if [[ "$tool_name" == "Bash" && -n "$bash_command" ]]; then
    sub_destructive=$(bash_detect_destructive_subagent "$bash_command" 2>/dev/null) || sub_destructive=""
    if [[ -n "$sub_destructive" ]]; then
      block "Subagents cannot run destructive command: $sub_destructive (main chat may run this manually)"
    fi
  fi

  # Subagent Write/Edit/NotebookEdit target wall
  if [[ "$tool_name" == "Write" || "$tool_name" == "Edit" || "$tool_name" == "NotebookEdit" ]]; then
    # Reject paths containing `..` segments outright. The
    # `.worktrees/...` substring regex below is a positive containment check,
    # but a crafted path like
    # `<repo>/.worktrees/x/task-1/../../../../etc/poison` matches the substring
    # while shell path-resolution lands outside the worktree. Pre-rejecting `..`
    # closes the canonicalization gap without requiring realpath (which itself
    # fails for not-yet-existing Write targets).
    case "$file_path" in
      *"/../"*|*"/.."|"../"*|"..")
        block "Subagent target rejected (path contains '..' segment): $file_path"
        ;;
    esac
    # The task-NN[a-z]? alpha suffix supports baseline-fix-of-baseline-fix
    # tasks (task-00b, task-00c). MUST match worktree_extract_slug's regex.
    if ! [[ "$file_path" =~ \.worktrees/[^/]+/(task-[0-9]+[a-z]?|baseline)(/|$) ]]; then
      block "Subagent target outside worktree: $file_path"
    fi
  fi

  # Subagent Bash write detection target wall
  if [[ "$tool_name" == "Bash" && -n "$bash_command" ]]; then
    detected_targets=$(bash_detect_file_writes "$bash_command" 2>/dev/null) || detected_targets=""
    if [[ -n "$detected_targets" ]]; then
      while IFS= read -r tgt; do
        [[ -z "$tgt" ]] && continue
        # __OPAQUE_WRITE__ is the bash-detect sentinel
        # for write targets that cannot be statically resolved (inline
        # interpreters like `python -c`, awk-with-redirect, or a
        # cd-before-relative-write where the shell's effective CWD diverges
        # from the hook PWD). The hook MUST fail closed on these — the
        # apparent "target" cannot be trusted to live inside the worktree.
        # Match before any PWD-prepend so the worktree-regex cannot
        # accidentally allow the sentinel by virtue of PWD living inside a
        # worktree.
        if [[ "$tgt" == "__OPAQUE_WRITE__" ]]; then
          block "Subagent Bash write target unresolvable (inline interpreter, cd-out, or unparseable redirect): treated as outside-worktree (fail-closed)"
        fi
        # Reject `..` segments before regex containment match.
        case "$tgt" in
          *"/../"*|*"/.."|"../"*|"..")
            block "Subagent Bash target rejected (path contains '..' segment): $tgt"
            ;;
        esac
        # Resolve relative paths to absolute (best effort using PWD)
        abs_tgt="$tgt"
        [[ "$tgt" != /* ]] && abs_tgt="$PWD/$tgt"
        case "$abs_tgt" in
          *"/../"*|*"/.."|"../"*|"..")
            block "Subagent Bash target rejected (path contains '..' segment): $tgt"
            ;;
        esac
        if ! [[ "$abs_tgt" =~ \.worktrees/[^/]+/(task-[0-9]+[a-z]?|baseline)(/|$) ]]; then
          block "Subagent Bash target outside worktree: $tgt"
        fi
      done <<< "$detected_targets"
    fi
  fi
fi

# ── Hook-managed `.qrspi/` write protection (everyone) ───────────────────────
# The hook is the only writer of `.qrspi/state.json`, `.qrspi/audit.jsonl`,
# `.qrspi/task-NN-runtime.json`, and `.qrspi/audit-codex-review.jsonl`. These
# files exist at both repo-root (where state_write_atomic runs) and
# `<artifact_dir>/.qrspi/` (where audit_log_event writes). Both locations must
# be protected from non-hook writers.
#
# Two-tier check:
#   1. Specific hook-managed files via is_protected_qrspi_target (canonical
#      single source of truth).
#   2. The broader artifact-dir `.qrspi/` directory regex (existing behaviour
#      retained as defense-in-depth — covers any future file added under
#      `docs/qrspi/<slug>/.qrspi/`).
check_artifact_qrspi_protection() {
  local target="$1"
  if is_protected_qrspi_target "$target"; then
    block "Cannot write to hook-managed .qrspi/ file: $target"
  fi
  if [[ "$target" =~ (^|/)docs/qrspi/[^/]+/\.qrspi(/|$) ]]; then
    block "Cannot write to artifact_dir .qrspi/ (audit log is hook-managed): $target"
  fi
}

if [[ "$tool_name" == "Write" || "$tool_name" == "Edit" || "$tool_name" == "NotebookEdit" ]]; then
  check_artifact_qrspi_protection "$file_path"
fi

if [[ "$tool_name" == "Bash" && -n "$bash_command" ]]; then
  detected_for_protection=$(bash_detect_file_writes "$bash_command" 2>/dev/null) || detected_for_protection=""
  if [[ -n "$detected_for_protection" ]]; then
    while IFS= read -r tgt; do
      [[ -z "$tgt" ]] && continue
      # Skip the opaque sentinel — `__OPAQUE_WRITE__` is not a real path, so
      # the .qrspi/ protection regex cannot meaningfully match it. The
      # subagent wall (above) is responsible for failing closed on opaque
      # targets; main chat is trusted on opaque writes.
      [[ "$tgt" == "__OPAQUE_WRITE__" ]] && continue
      abs_tgt="$tgt"
      [[ "$tgt" != /* ]] && abs_tgt="$PWD/$tgt"
      check_artifact_qrspi_protection "$abs_tgt"
    done <<< "$detected_for_protection"
  fi
fi

# All checks passed
allow
