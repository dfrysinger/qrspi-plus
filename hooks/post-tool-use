#!/usr/bin/env bash
# PostToolUse hook for QRSPI plugin
# Responsibilities:
#   1. Artifact state sync — for Write/Edit/NotebookEdit targeting known
#      QRSPI artifacts (goals.md, design.md, etc.). Updates state.json
#      artifact statuses and recomputes current_step on approval.
# Always exits 0 (non-blocking, async).
#
# Audit logging is OWNED by pre-tool-use (audits the decision: allow/block).
# Post-tool-use does NOT audit — would produce duplicate "allow" rows for
# every successful Write/Edit, polluting the log.
#
# NEVER SILENT: All errors and unexpected conditions are logged to both
# stderr (user sees in diagnostics) and .qrspi/errors.log (persistent
# record that survives session scrollback). Non-blocking does not mean silent.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Source libraries
source "$PLUGIN_ROOT/hooks/lib/artifact.sh"  # transitively gets pipeline, state, frontmatter
source "$PLUGIN_ROOT/hooks/lib/audit.sh"     # for _audit_resolve_target_to_artifact_dir

# Log errors to stderr.
log_error() {
  local msg="$1"
  echo "post-tool-use: ${msg}" >&2
}

# Read stdin
stdin_json=$(cat)

# Parse tool_name
tool_name=$(printf '%s' "$stdin_json" | jq -r '.tool_name // empty' 2>/dev/null) || {
  log_error "ERROR: malformed JSON on stdin — state sync skipped for this tool call"
  exit 0
}
if [[ -z "$tool_name" ]]; then
  log_error "ERROR: missing tool_name in stdin JSON — state sync skipped for this tool call"
  exit 0
fi

# Only Write/Edit/NotebookEdit need artifact state sync — Bash never targets
# a QRSPI artifact through normal pipeline flow.
if [[ "$tool_name" != "Write" && "$tool_name" != "Edit" && "$tool_name" != "NotebookEdit" ]]; then
  # Warn on unrecognized tool names so silent tool additions don't slip past.
  case "$tool_name" in
    Read|Glob|Grep|Skill|ToolSearch|Agent|TodoRead|TodoWrite|WebFetch|WebSearch|Bash)
      ;;
    *)
      echo "post-tool-use: WARNING: unrecognized tool_name '${tool_name}' — no state sync" >&2
      ;;
  esac
  exit 0
fi

# Extract file_path
file_path=$(printf '%s' "$stdin_json" | jq -r '.tool_input.file_path // empty' 2>/dev/null) || {
  log_error "WARNING: cannot parse file_path from ${tool_name} tool input — state sync skipped"
  exit 0
}
if [[ -z "$file_path" ]]; then
  exit 0
fi

# Resolve target → artifact_dir. Convert relative paths to absolute first so
# the resolver's prefix match against $(pwd)/docs/qrspi/ works.
abs_file_path="$file_path"
[[ "$file_path" != /* ]] && abs_file_path="$PWD/$file_path"

artifact_dir=$(_audit_resolve_target_to_artifact_dir "$abs_file_path" 2>/dev/null) || {
  # Target is outside any QRSPI artifact_dir. Usually nothing to sync, BUT if
  # the file_path matches a known artifact name (goals.md, design.md, etc.) we
  # have a real architectural drift: pre-tool-use blocks unresolved artifacts,
  # so reaching here means the layout is inconsistent. Log a stderr warning so
  # the user notices the silent state-sync skip.
  if artifact_map_get_step "$file_path" >/dev/null 2>&1; then
    log_error "WARNING: ${file_path} matches a QRSPI artifact name but no artifact_dir resolved — state.json sync skipped (state may now be stale; investigate the path layout)"
  fi
  exit 0
}

# Sync state if this is a known artifact within the resolved artifact_dir.
artifact_exit=0
step_name=$(artifact_is_known "$file_path" "$artifact_dir" 2>/dev/null) || artifact_exit=$?
if [[ $artifact_exit -eq 2 ]]; then
  log_error "WARNING: artifact_is_known returned error for ${file_path} — state sync skipped"
  exit 0
fi
if [[ -n "$step_name" ]]; then
  if ! artifact_sync_state "$file_path" "$artifact_dir" 2>/dev/null; then
    log_error "ERROR: artifact_sync_state failed for ${step_name} (${file_path}) — state.json may be stale"
  fi
fi

exit 0
